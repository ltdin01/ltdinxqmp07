# ==============================================================================
# TARGET WEBSITE REPOSITORY CONFIGURATION (Cross-Repo Sync)
# ==============================================================================
TARGET_REPO_OWNER=kryptobolt07
TARGET_REPO_NAME=laptopdeals
TARGET_REPO_BRANCH=main

# Personal Access Token (PAT) with 'repo' or fine-grained 'Contents: read/write' scope
# Configured as a GitHub Secret 'TARGET_REPO_PAT' in the scripts repository settings
TARGET_REPO_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Automated Commit Author Info
GIT_COMMIT_AUTHOR_NAME=laptopdeals-bot[bot]
GIT_COMMIT_AUTHOR_EMAIL=bot@laptopdeals.local

# ==============================================================================
# PIPELINE SCRAPING & WORKER SETTINGS
# ==============================================================================
DEFAULT_SCRAPE_SERIES=LOQ ThinkPad Legion IdeaPad ThinkBook Yoga
MAX_SCRAPE_WORKERS=8
MAX_PRICE_WORKERS=6
MAX_CTO_WORKERS=4
BITBNS_WORKERS=1
BITBNS_DELAY=5.0
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_MIN_DELAY_SECONDS=1.0
HTTP_MAX_DELAY_SECONDS=3.0

# Optional Proxy URL (e.g. http://user:pass@proxy.example.com:8080)
# HTTP_PROXY=

# ==============================================================================
# LENOVO & PSREF API ENDPOINTS
# ==============================================================================
LENOVO_BASE_URL=https://www.lenovo.com
LENOVO_SITE_BASE=https://www.lenovo.com/in/en
LENOVO_OPENAPI_BASE=https://openapi.lenovo.com/in/en
PSREF_MENU_URL=https://psref.lenovo.com/api/home/menu/info
PSREF_EXPORT_URL=https://psref.lenovo.com/api/search/DefinitionFilterAndSearch/ShowModelExcelExport

# ==============================================================================
# SUPABASE / EXTERNAL DATABASE KEYS (OPTIONAL)
# ==============================================================================
# SUPABASE_URL=https://xyz.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOi...
